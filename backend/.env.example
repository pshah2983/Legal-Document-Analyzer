# ==============================================================================
# LEGAL DOCUMENT ANALYZER - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to '.env' and fill in your details.
# If these are left blank, the application automatically runs in developer offline mode:
# - In-Memory Local Qdrant (no cluster needed)
# - Mock LLM Response Generators (no Groq key needed)
# ==============================================================================

# Port to bind backend server (FastAPI)
PORT=8000

# Groq API Configuration (for Llama 3 reasoning)
GROQ_API_KEY=

# Qdrant Cloud Cluster Configuration
QDRANT_URL=
QDRANT_API_KEY=
